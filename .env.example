# Anvil Staking Tool
# NEVER commit this file!

# Wallet private key (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# ApeChain RPC endpoint
APECHAIN_RPC_URL=https://rpc.apechain.com

# Etherscan API v2 key (required for token discovery)
# Get one at https://etherscan.io/myapikey (works for all chains including ApeChain)
APESCAN_API_KEY=YOUR_API_KEY_HERE

# Collection configs (JSON array)
# Find staking contract addresses by staking 1 NFT manually on anvil.clutch.market,
# then check the "To" address of that tx on ApeScan
COLLECTIONS=[{"name":"Savage Apes","nft_address":"0x7e3cba2eb90cc27d34bb9475fc85cfafe12df47a","staking_address":"0xd5B10C91568CE8E841d88cDa880846705A423b91"}]

# Auto-stake interval in seconds (0 = disabled)
AUTO_STAKE_INTERVAL=60

# Max token IDs to scan with ownerOf fallback (if API unavailable)
NFT_SCAN_MAX_RANGE=20000
